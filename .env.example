# =====================================================================
# Lab Register Management System - Environment Configuration
# Copy this file to ".env" and fill in your real values.
# NEVER commit your real .env file to version control.
# =====================================================================

# ---------- Application ----------
# Port the Kiosk server listens on (default 3000)
PORT=3000

# Session secret (use a long random string in production)
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-string

# Session cookie security. Set to "true" ONLY when serving over HTTPS
# (behind a TLS-terminating reverse proxy). This adds the Secure attribute so
# the cookie is only sent over HTTPS. Leave "false" for the offline/local
# kiosk (the default — required for plain-HTTP access).
SECURE_COOKIE=false

# ---------- Branding (shown on Home + Admin) ----------
UNIVERSITY_NAME=Srinivas University
LAB_NAME=Computer Laboratory Register

# ---------- Admin Credentials ----------
# Password is hashed with bcrypt on first run and stored in SQLite.
# Provide the PLAINTEXT password here; it is only used to seed the admin
# account if no admin exists yet. Reset by changing here + restarting.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ---------- SQLite (Primary / Offline) ----------
# Path is relative to project root.
SQLITE_DB_PATH=./data/labregister.db

# ---------- MongoDB Atlas (Cloud Backup) ----------
# Leave blank to run fully offline (SQLite only).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/labregister?retryWrites=true&w=majority

# ---------- Sync ----------
# Interval in seconds between background cloud sync attempts.
SYNC_INTERVAL_SECONDS=30

# ---------- Backup ----------
# Nightly backup time (24h). Cron = "m h * * *"
BACKUP_TIME=23:55
BACKUP_KEEP=30

# ---------- Network Check ----------
# URL used to probe internet connectivity during sync.
INTERNET_CHECK_URL=https://www.google.com/generated_404_probe

# ---------- Theme ----------
# "light" or "dark"
DEFAULT_THEME=light

# ---------- Kiosk Registration Policy ----------
# "true"  -> students may self-register at the kiosk (default).
# "false" -> kiosk registration disabled; students must be added by an admin.
# Overridable at runtime via Settings (stored in the `settings` table).
ALLOW_SELF_REGISTRATION=true
